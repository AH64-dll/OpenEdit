# Open Edit — example environment file
# ====================================
#
# Copy this file to `.env` and fill in the values you need. Open Edit
# loads from the process environment; this file is for reference only
# (the CLI doesn't auto-load it — use `export KEY=value` or a
# dotenv loader if you want).
#
# Never commit a real .env file; it's in .gitignore. The values below
# are placeholders.

# ---------------------------------------------------------------
# LLM provider
# ---------------------------------------------------------------

# Which LLM provider to use. The pi provider runs the pi CLI as a
# subprocess and reads our TypeScript extension. The anthropic /
# openai providers hit those SDKs directly.
# OPEN_EDIT_LLM_PROVIDER=pi

# Anthropic API key (required for the "anthropic" provider).
# OPEN_EDIT_LLM_API_KEY=sk-ant-...

# Model name (defaults: claude-sonnet-4-5 / gpt-4o / minimax-m3).
# OPEN_EDIT_LLM_MODEL=minimax-m3

# Per-turn cap (Anthropic only). Default 4096.
# OPEN_EDIT_LLM_MAX_TOKENS=4096

# pi-specific overrides. The defaults work for the standard install.
# OPEN_EDIT_PI_BINARY=pi
# OPEN_EDIT_PI_PROVIDER=opencode-go

# ---------------------------------------------------------------
# Projects
# ---------------------------------------------------------------

# Root folder for the project registry. Each subfolder that contains
# `.open_edit/edit_graph.db` is a project. Default: ~/OpenEditProjects.
# OPEN_EDIT_PROJECTS_ROOT=/home/youruser/OpenEditProjects

# ---------------------------------------------------------------
# v1.4 P1-1 — Internet search (Pexels + Freesound)
# ---------------------------------------------------------------

# Pexels API key — used for video + photo search.
# Get one (free) at https://www.pexels.com/api/.
# 200 requests/hour, 20,000/month, raisable on request.
# OPEN_EDIT_PEXELS_API_KEY=

# Freesound API token — used for audio search + preview-quality
# downloads. Full-quality audio is OAuth2-only; the v1.4 first pass
# ships with preview-quality (lossy MP3) downloads.
# Get a token (free) at https://freesound.org/apiv2/apply.
# OPEN_EDIT_FREESOUND_API_KEY=

# Where the in-process search-result cache lives. Default is
# /tmp/open_edit_search_cache; override if /tmp is too small or
# shared with other tools.
# OPEN_EDIT_SEARCH_CACHE_DIR=/tmp/open_edit_search_cache

# ---------------------------------------------------------------
# v1.4 P1-2 — Chat status indicator (no env config needed)
# v1.4 P0-1 / P0-2 — Diagnostic + asset streaming (no env config)
# ---------------------------------------------------------------

# ---------------------------------------------------------------
# v1.5 — Visual verification loop
# ---------------------------------------------------------------
#
# After every ``trigger_render`` call, the server samples frames from
# the rendered MP4 and attaches them to the tool result, requiring the
# LLM to look at them and emit ``VERIFICATION: PASS|FAIL|UNCERTAIN``
# before the turn can end. See
# docs/superpowers/specs/2026-07-21-visual-verify-design.md.

# Master switch. Set to 0 to disable the verification stage entirely
# (the LLM no longer sees frames after renders). Per-project opt-out
# lives in ``project_meta.verify_disabled``.
# OPEN_EDIT_VERIFY_ENABLED=1

# Frame count override. Default is 3 (matches the 1-30s tier in the
# spec). Set higher for long videos, lower for short ones. The tiered
# sampling in serve/visual_verify.py still applies for clips under 1s.
# OPEN_EDIT_VERIFY_FRAMES=3

# Per-turn render cap. The 4th ``trigger_render`` call in a single turn
# returns ``render_capped`` as a tool-result error. Default: 3.
# OPEN_EDIT_VERIFY_MAX_RENDERS=3

# Frame processing knobs (advanced).
# OPEN_EDIT_VERIFY_MAX_EDGE_PX=1024       # downscale to this long edge
# OPEN_EDIT_VERIFY_JPEG_QUALITY=85        # ffmpeg -q:v value
# OPEN_EDIT_VERIFY_TOTAL_TIMEOUT_SECONDS=30
# OPEN_EDIT_VERIFY_MAX_IMAGE_BYTES=5242880  # 5 MiB; halves edge if exceeded
# OPEN_EDIT_VERIFY_DEBUG_DIR=             # set to a path to dump raw frames
# OPEN_EDIT_VERIFY_RENDER_MODE=proxy      # 'proxy' (default) or 'final'
# OPEN_EDIT_VERIFY_ALLOW_NO_CHANGE_SKIP=1 # skip re-render if project state unchanged
# OPEN_EDIT_VERIFY_PERSIST_HISTORY=1      # keep images in the on-disk conversation
